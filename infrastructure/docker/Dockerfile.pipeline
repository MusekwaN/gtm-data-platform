# infrastructure/docker/Dockerfile.pipeline
FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    kafka-python-ng \
    pandas \
    pyarrow \
    python-dotenv \
    prometheus-client \
    snowflake-connector-python \
    rapidfuzz \
    numpy

COPY simple_pipeline.py .
COPY monitoring/ ./monitoring/
COPY ai_agents/ ./ai_agents/
COPY reverse_etl/ ./reverse_etl/
COPY .env .env

CMD ["python", "simple_pipeline.py"]